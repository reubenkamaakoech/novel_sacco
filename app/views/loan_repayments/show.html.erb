
<div class="container">

<p>
  <strong>Loan Id:</strong>
  <%= @loan_repayment.loan_id %>
</p>

<p>
  <strong>Member:</strong>
  <%= @loan_repayment.member.name %> (<%= @loan_repayment.member.membership_number %>)
</p>

<p>
  <strong>Loan Amount:</strong>
  <%= number_to_currency(@loan_repayment.loan.amount, unit: "Ksh ") %>
</p>

<p>
  <strong>Repayment Amount:</strong>
  <%= number_to_currency(@loan_repayment.amount, unit: "Ksh ") %>
</p>

<p>
  <strong>Created by:</strong>
  <%= @loan_repayment.user.username %>
</p>

<div>
  <% if @loan_repayment.loan && @loan_repayment.loan.status && @loan_repayment.loan.balance > 0 %>
  <%= link_to "Edit this loan repayment",
      edit_loan_repayment_path(@loan_repayment),
      class: "btn btn-warning btn-sm" %>

  <%= link_to "Back to loan repayments",
      loan_repayments_path,
      class: "btn btn-primary btn-sm" %>

  <div class="mt-3">
    <%= button_to "Delete",
        @loan_repayment,
        method: :delete,
        data: { confirm: "Are you sure you want to delete this site?" },
        class: "btn btn-danger btn-sm" %>
  </div>

<% else %>

  <button class="btn btn-warning btn-sm" disabled title="Loan closed or fully paid">Edit</button>

  <%= link_to "Back to loan repayments",
      loan_repayments_path,
      class: "btn btn-primary btn-sm" %>

  <div class="mt-3">
    <button class="btn btn-danger btn-sm" disabled title="Loan closed or fully paid">Delete</button>
  </div>

<% end %>
</div>
</div>
