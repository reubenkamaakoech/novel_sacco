
<div class="container">

<p>
  <strong>Loan Id:</strong>
  <%= @loan_repayment.loan_id %>
</p>

<p>
  <strong>Member:</strong>
  <%= @loan_repayment.member.name %> (<%= @loan_repayment.member.membership_number %>)
</p>

<p>
  <strong>Loan Amount:</strong>
  <%= number_to_currency(@loan_repayment.loan.amount, unit: "Ksh ") %>
</p>

<p>
  <strong>Repayment Amount:</strong>
  <%= number_to_currency(@loan_repayment.amount, unit: "Ksh ") %>
</p>

<p>
  <strong>Created by:</strong>
  <%= @loan_repayment.user.username %>
</p>

<div>
  <%= link_to "Edit this loan repayment", edit_loan_repayment_path(@loan_repayment), class:"btn btn-warning btn-sm" %> |
  <%= link_to "Back to loan repayments", loan_repayments_path, class:"btn btn-primary btn-sm" %>
</div>

<div class="mt-3">
  <%= button_to "Delete", @loan_repayment, method: :delete, data: { confirm: "Are you sure you want to delete this site?" }, class: "btn btn-danger btn-sm" %>
</div>
</div>
