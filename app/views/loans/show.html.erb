<div class="container">
  <p>
    <strong>Member:</strong>
    <%= @loan.member.name %>
  </p>

  <p>
    <strong>Loan Amount:</strong>
    <%= number_to_currency(@loan.amount, unit: "Ksh ") %>
  </p>

  <p>
    <strong>Payment Period:</strong>
    <%= @loan.payment_period_months %> Months
  </p>

  <p>
    <strong>Repayment Amount per Month:</strong>
    <%= number_to_currency(@loan.repayment_amount_per_month, unit: "Ksh ") %>
  </p>

  <div>
    <%= link_to "Edit this loan", edit_loan_path(@loan), class:"btn btn-warning btn-sm" %> |
    <%= link_to "Back to loans", loans_path, class:"btn btn-primary btn-sm" %>
  </div>

  <div class="mt-3">
    <%= button_to "Delete", @loan, method: :delete, data: { confirm: "Are you sure you want to delete this loan?" }, class: "btn btn-danger btn-sm" %>
  </div>

  <hr>

  <h4>Loan Repayments</h4>
  <% if @loan.loan_repayments.any? %>
    <table class="table table-striped mt-2">
      <thead class="table-primary">
        <tr>
          <th>ID</th>
          <th>Amount</th>
          <th>Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @loan.loan_repayments.each do |repayment| %>
          <tr>
            <td><%= repayment.id %></td>
            <td><%= number_to_currency(repayment.amount, unit: "Ksh ") %></td>
            <td><%= repayment.created_at.strftime("%d-%b-%Y") %></td>
            <td>
              <%= link_to "Edit", edit_loan_repayment_path(repayment), class: "btn btn-warning btn-sm" %>
            </td>
            <td>
              <%= button_to "Delete", repayment, method: :delete, data: { confirm: "Delete this repayment?" }, class: "btn btn-danger btn-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p>No repayments have been made for this loan yet.</p>
  <% end %>

  <div class="mt-2">
    <%= link_to "Add Repayment", new_loan_repayment_path(loan_id: @loan.id), class: "btn btn-success btn-sm" %>
  </div>
</div>