<div class="container mt-4">

  <table class="table table-striped table-light">
    <thead class="table-primary">
      <tr>
        <th>ID</th>
        <th>Status</th>
        <th>Name</th>
        <th>Monthly Contribution</th>
        <th>Membership Number</th>
        <th colspan="3">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @members.each do |member| %>
        <tr>
          <td><%= member.id %></td>
          <td>
            <%= render "members/status_toggle", member: member %>
          </td>
          <td><%= member.name %></td>
          <td><%= number_to_currency(member.monthly_contribution, unit: "Ksh ") %></td>
          <td><%= member.membership_number %></td>

          <td><%= link_to "Show", member_path(member), class: "btn btn-primary btn-sm" %></td>
          <td><%= link_to "View ID Card", id_card_member_path(member), class: "btn btn-info btn-sm", target: "_blank" %></td>
          <td><%= link_to "View Statement", member_statement_path(member_id: member.id), class: "btn btn-info btn-sm" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

